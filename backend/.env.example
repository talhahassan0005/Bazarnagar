# Server
PORT=5000
NODE_ENV=development

# Allowed frontend origin for CORS (the Next.js app)
CLIENT_ORIGIN=http://localhost:3000

# MongoDB — local mongod OR a MongoDB Atlas connection string
MONGODB_URI=mongodb://127.0.0.1:27017/bazaarnagar

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Public base URL of THIS backend (used to build absolute image URLs)
PUBLIC_URL=http://localhost:5000

# Frontend base URL for Stripe redirects (onboarding / checkout return)
APP_URL=http://localhost:3000

# Stripe — leave blank to keep online card payments disabled.
# Test keys: https://dashboard.stripe.com/test/apikeys  (enable Connect for marketplace payouts)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Seed an admin account (used by `npm run seed`)
ADMIN_EMAIL=admin@bazaarnagar.com
ADMIN_PASSWORD=admin123
